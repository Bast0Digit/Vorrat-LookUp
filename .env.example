# Vorrat-LookUp - environment variables
# Copy to .env.local (gitignored) and fill in. Never commit real keys.

# Supabase project (shared instance, this app uses the `vorrat` schema only)
NEXT_PUBLIC_SUPABASE_URL=https://ggaiorygjkjhbfkvrfmb.supabase.co
# Publishable/anon key - safe for the browser. From:
# Supabase Dashboard > Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only. Never expose to the client bundle. Only for admin/server tasks.
# Supabase Dashboard > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
